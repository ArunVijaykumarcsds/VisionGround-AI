# =============================================================
# Locate Anything — Frontend Environment Variables
# =============================================================
# Copy to .env and adjust for your deployment target.
# All variables must be prefixed with VITE_ to be exposed to the browser.

# Backend API base URL.
# During local development (npm run dev) the Vite proxy handles this,
# so the default empty string works fine.
# For Docker / production deployments, set to the backend URL.
VITE_API_URL=http://localhost:8000
