# =============================================================
# Locate Anything Assistant - Backend Environment Variables
# =============================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ------------------------------------------------------------------
# MODEL CONFIGURATION
# ------------------------------------------------------------------
# Hugging Face model ID or local path to LocateAnything-3B weights.
# Use "nvidia/LocateAnything-3B" to download automatically from HF Hub,
# or set an absolute path to a locally cached directory.
MODEL_PATH=nvidia/LocateAnything-3B

# Hugging Face API token (required to download gated / private models).
# Generate one at https://huggingface.co/settings/tokens
HF_TOKEN=your_hf_token_here

# Device to run the model on: "cuda", "cpu", or "auto" (auto-detects GPU).
DEVICE=auto

# Torch dtype for inference: "bfloat16" | "float16" | "float32"
# BF16 is recommended for Ampere+ GPUs.  CPU should use float32.
TORCH_DTYPE=bfloat16

# ------------------------------------------------------------------
# INFERENCE CONFIGURATION
# ------------------------------------------------------------------
# Generation mode for LocateAnything: "hybrid" | "fast" | "slow"
# "hybrid" (default) balances speed and accuracy.
GENERATION_MODE=hybrid

# Maximum number of new tokens the model can generate per request.
MAX_NEW_TOKENS=2048

# Sampling temperature (0 = greedy, >0 = stochastic).
TEMPERATURE=0.7

# Top-p nucleus sampling probability mass.
TOP_P=0.9

# Repetition penalty (1.0 = no penalty).
REPETITION_PENALTY=1.1

# ------------------------------------------------------------------
# SERVER CONFIGURATION
# ------------------------------------------------------------------
# Host and port for the FastAPI / Uvicorn server.
HOST=0.0.0.0
PORT=8000

# Number of Uvicorn worker processes.
# Use 1 when the model is loaded in-process (recommended for GPU).
WORKERS=1

# Log level: "debug" | "info" | "warning" | "error"
LOG_LEVEL=info

# ------------------------------------------------------------------
# IMAGE / UPLOAD LIMITS
# ------------------------------------------------------------------
# Maximum allowed image upload size in megabytes.
MAX_IMAGE_SIZE_MB=20

# Maximum image dimension (width or height) in pixels.
# Images exceeding this will be downscaled before inference.
MAX_IMAGE_DIMENSION=2560

# Allowed image MIME types (comma-separated).
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/bmp

# ------------------------------------------------------------------
# CORS CONFIGURATION
# ------------------------------------------------------------------
# Comma-separated list of allowed origins for the frontend.
# Use "*" in development; restrict in production.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ------------------------------------------------------------------
# CACHE / MODEL DOWNLOAD
# ------------------------------------------------------------------
# Directory where Hugging Face Hub caches downloaded models.
# Defaults to ~/.cache/huggingface/hub if left empty.
HF_HOME=

# If set to "1", forces re-download of model files.
FORCE_DOWNLOAD=0

# ------------------------------------------------------------------
# MONITORING
# ------------------------------------------------------------------
# Enable memory usage logging on each inference request.
ENABLE_MEMORY_LOGGING=true

# Inference timing log threshold in milliseconds.
# Requests slower than this value will be flagged in logs.
SLOW_INFERENCE_THRESHOLD_MS=5000
